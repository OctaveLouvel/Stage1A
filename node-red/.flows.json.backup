    {
        "id": "3e832aa260cde4be",
        "type": "function",
        "z": "37999168f7331a03",
        "g": "80473e158615c07b",
        "name": "function 4",
        "func": "const forbidden = [\n    \"depth\",\n    \"infra\",\n    \"compressed\",\n    \"compressedDepth\",\n    \"theora\",\n    \"zstd\",\n    \"metadata\",\n    \"camera_info\",\n    \"extrinsics\"\n];\n\nlet topics = msg.payload.split(\"\\n\");\n\ntopics = topics\n    .map(t => t.trim())\n    .filter(t =>\n        t.length > 0 &&\n        !forbidden.some(word => t.includes(word))\n    );\n\nmsg.ui_update = {};\n\nmsg.payload = \"\"\n\nmsg.ui_update.options = topics.map(topic => ({\n    value: \"http://localhost:8080/stream?topic=\" +\n           topic,\n    label: topic\n}));\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1700,
        "y": 260,
        "wires": [
            [
                "1fba95fd6322f2c6"
            ]
        ]
