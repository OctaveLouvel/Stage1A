    {
        "id": "a024c7f35c51da3c",
        "type": "function",
        "z": "7eac0d34c6842661",
        "g": "db6e9ffd1ee575de",
        "name": "set topics",
        "func": "let topics = flow.get(\"topics\") || []\nlet split = msg.payload.split(\" \")\n\nlet topic = split[0];\nlet type = split[1];\nlet selected = false;\n\ntopics.push(\n{\n    topic: topic,\n    type: type,\n    selected: selected\n}\n)\n\nflow.set(\"topics\", topics);\nmsg.payload = topics;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
        "y": 100,
        "wires": [
            [
                "4d8a2e2e37a13832"
            ]
        ]
    },
    {
        "id": "36a3fe263df9fbab",
        "type": "function",
        "z": "7eac0d34c6842661",
        "g": "db6e9ffd1ee575de",
        "name": "reset topics",
        "func": "let topics = []\n\nflow.set(\"topics\", topics);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 490,
        "y": 220,
        "wires": [
            []
        ]
    },
    {
        "id": "9e0d58542b489367",
        "type": "function",
        "z": "7eac0d34c6842661",
        "g": "db6e9ffd1ee575de",
        "name": "set topics",
        "func": "let topics = flow.get(\"topics\") || [];\n\nlet selecteds = msg.payload;\n\ntopics.forEach(function(element) {\n    element.selected = false;\n});\n\nselecteds.forEach(function(select) {\n    let i = topics.findIndex(t => t.topic === select.topic);\n    if (i !== -1) {\n        topics[i].selected = true;\n    }else{\n        topics[i].selected = false;\n    }\n});\n\nflow.set(\"topics\", topics);\nmsg.payload = topics\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 180,
        "wires": [
            []
        ]
    },
