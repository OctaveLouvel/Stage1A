    {
        "id": "0ccfcf9c98d31575",
        "type": "function",
        "z": "37999168f7331a03",
        "g": "2d2a5e96dc4978ef",
        "name": "set_movement",
        "func": "let joints = flow.get(\"joints\") || [0,0,0,0,0,0];\n\njoints[msg.joint] = Number(msg.payload) * Math.PI / 180;;\n\nflow.set(\"joints\", joints);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 360,
        "wires": [
            []
        ]
    },
