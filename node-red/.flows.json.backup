    {
        "id": "47f587318557bdf9",
        "type": "function",
        "z": "7eac0d34c6842661",
        "g": "86aa23bf3b1e6449",
        "name": "refactor bags infos",
        "func": "const info = msg.payload.rosbag2_bagfile_information;\n\nmsg.payload = [{\n    name: info.relative_file_paths[0].replace(\"_0.mcap\", \"\"),\n    duration: (info.duration.nanoseconds / 1e9).toFixed(2) + \" s\",\n    messages: info.message_count,\n    topics: info.topics_with_message_count.length,\n    storage: info.storage_identifier,\n    distro: info.ros_distro\n}];\n\nreturn msg;",
