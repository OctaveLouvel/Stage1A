        "func": "let joints = {};\n\nfor (let i = 0; i < msg.payload.name.length; i++) {\n    joints[msg.payload.name[i]] = (msg.payload.position[i] * 180 / Math.PI).toFixed(2) + \"°\";\n}\n\nreturn [\n    { payload: joints.shoulder_pan_joint },\n    { payload: joints.shoulder_lift_joint },\n    { payload: joints.elbow_joint },\n    { payload: joints.wrist_1_joint },\n    { payload: joints.wrist_2_joint },\n    { payload: joints.wrist_3_joint }\n];",
