    {
        "id": "c26056e51157a08f",
        "type": "function",
        "z": "37999168f7331a03",
        "g": "2d2a5e96dc4978ef",
        "name": "recuperation joint pose",
        "func": "let joints = flow.get(\"joints\") || [0,0,0,0,0,0];\n\nmsg.payload = {\n    joint_names: [\n        \"shoulder_pan_joint\",\n        \"shoulder_lift_joint\",\n        \"elbow_joint\",\n        \"wrist_1_joint\",\n        \"wrist_2_joint\",\n        \"wrist_3_joint\"\n    ],\n    points: [\n        {\n            positions: joints,\n            time_from_start: {\n                sec: 3,\n                nanosec: 0\n            }\n        }\n    ]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 100,
        "wires": [
