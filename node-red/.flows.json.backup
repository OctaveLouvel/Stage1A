        "type": "function",
        "z": "7eac0d34c6842661",
        "g": "86aa23bf3b1e6449",
        "name": "Bag selection",
        "func": "msg.ui_update = {};\n\nlet str = msg.payload;\nlet options = str.split('\\n');\noptions.pop();\n\nmsg.ui_update.options = []\noptions.forEach(function(element) {\n    msg.ui_update.options.push(\n        {\n            value: element\n        }\n    )\n});\n\nreturn msg;",
        "outputs": 1,
