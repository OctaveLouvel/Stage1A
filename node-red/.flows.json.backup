        "type": "function",
        "z": "7eac0d34c6842661",
        "g": "86aa23bf3b1e6449",
        "name": "Set args",
        "func": "let topics = flow.get(\"topics\") || [];\nlet name = flow.get(\"name\") || \"\";\nlet args = \"\";\n\n\ntopics.forEach(function(topic) {\n    if(topic.selected){\n        args += topic.topic + \" \";\n    }\n});\n\nif(name != \"\" || name != null){\n    args += \"-o bags/\" + name;\n    msg.args = args;\n}else{\n    return Error\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
